# URL de conexión a la base de datos (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Zona horaria
TZ=Europe/Madrid

# Puerto del servidor backend
PORT=4000

# URL pública del frontend para CORS y Socket.io
FRONTEND_URL="http://localhost:5173"

# Secreto JWT para autenticación del panel
JWT_SECRET="replace_with_a_long_random_secret"

# Google Maps API (Opcional, para geolocalización o lugares)
GOOGLE_API_KEY="your_api_key_here"
GOOGLE_PLACE_ID="your_place_id_here"

# Configuración SMTP para envío de correos
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=465
SMTP_USER="user@example.com"
SMTP_PASS="your_app_password"
SMTP_FROM="Name <user@example.com>"

# Opcional: fuerza todos los correos a una dirección de pruebas
EMAIL_OVERRIDE_RECIPIENT=""
